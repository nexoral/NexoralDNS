{
  "version": "1.0",
  "description": "GitHub Copilot CLI settings for NexoralDNS - Advanced DNS Management System",

  "project": {
    "name": "NexoralDNS",
    "type": "typescript",
    "language": "TypeScript",
    "runtime": "Node.js ≥18.0.0",
    "architecture": "7-Layer DNS Query Processing"
  },

  "build": {
    "server": {
      "command": "cd server && npm run build",
      "required": true,
      "runAfterChanges": true
    },
    "web": {
      "command": "cd Web && npm run build",
      "required": true
    },
    "dhcp": {
      "command": "cd DHCP && npm run build",
      "required": true
    }
  },

  "test": {
    "command": "cd Test && npm test",
    "required": true,
    "location": "Test/"
  },

  "deployment": {
    "allowedEnvironments": ["lan", "local"],
    "forbiddenEnvironments": ["cloud", "public", "internet"],
    "warning": "LAN-ONLY: Never deploy to cloud/public networks. ISPs will block DNS spoofing."
  },

  "codeStyle": {
    "strictMode": true,
    "noAnyTypes": true,
    "preferConst": true,
    "preferArrowFunctions": true,
    "useTemplateStrings": true
  },

  "instructions": [
    "CRITICAL: LAN-ONLY deployment - Never suggest cloud/public hosting",
    "CRITICAL: Always run build after code changes in respective module",
    "CRITICAL: Update tests in Test/ for ANY feature change",
    "CRITICAL: Performance targets: <2ms cache, <5ms DB, <50ms upstream",
    "CRITICAL: Never throw exceptions in DNS query path - return valid DNS responses",
    "Follow 7-Layer DNS processing architecture (see ARCHITECTURE.md)",
    "TypeScript strict mode - No 'any' types, use proper interfaces",
    "Cache first: Check Redis before DB or upstream DNS",
    "Parallel operations: Use Promise.all instead of sequential await",
    "Graceful error handling: Return NXDOMAIN/SERVFAIL on errors",
    "Validate DNS queries: Check domain length, characters, label sizes",
    "Rate limiting: Max 100 queries/minute per client IP",
    "Backward compatibility: No breaking changes without versioning",
    "Update documentation: README.md, ARCHITECTURE.md, FEATURES.md when features change"
  ],

  "patterns": {
    "7LayerArchitecture": {
      "description": "All DNS queries go through 7 layers of processing",
      "layers": [
        "Layer 1: Cache (Redis) - 0.5-1ms",
        "Layer 2: Service Status - 0.5ms",
        "Layer 3: Block List - 0.5ms",
        "Layer 4: Client Plan - 1ms",
        "Layer 5: Custom Records - 2ms",
        "Layer 6: Domain Rerouting - 1ms",
        "Layer 7: Upstream DNS - 20-50ms"
      ]
    },
    "errorHandling": {
      "dnsPath": "Never throw - return NXDOMAIN/SERVFAIL",
      "apiPath": "Return 500 with error message",
      "logging": "Log detailed errors with context"
    },
    "naming": {
      "files": "{Feature}.service.ts, {Model}.schema.ts, {Feature}.controller.ts",
      "classes": "PascalCase (RulesService, DNSPacketHandler)",
      "methods": "camelCase verbs (processQuery, validateDomain)",
      "variables": "camelCase descriptive (dnsQuery, clientIP)",
      "constants": "UPPER_SNAKE_CASE (MAX_QUERY_SIZE, DEFAULT_TTL)"
    }
  },

  "structure": {
    "server": {
      "core": "DNS packet handler, Fastify server",
      "services": "7-layer processing logic (Rules, Cache, BlockList)",
      "database": "MongoDB schemas & connections",
      "cluster": "Multi-process cluster mode"
    },
    "Web": "React admin dashboard (Vite)",
    "DHCP": "DHCP server (TypeScript)",
    "Test": "Test suites (dns, cache, blocklist, performance)",
    "client": "Client SDK",
    "Docs": "Documentation site"
  },

  "security": [
    "Validate all DNS queries (length, characters, labels)",
    "Rate limiting: 100 queries/minute per client IP",
    "Client authentication and plan validation",
    "Never log sensitive data",
    "LAN-only deployment (port 53 not exposed to internet)"
  ],

  "performance": [
    "Cache first: Check Redis before DB/upstream",
    "Parallel operations: Use Promise.all",
    "Batch DB queries: Use $in operator",
    "Connection pooling: MongoDB and Redis",
    "Cluster mode: Utilize all CPU cores"
  ],

  "antiPatterns": [
    "Never use 'any' types",
    "Never suggest cloud/public deployment",
    "Never ignore performance targets",
    "Never break backward compatibility",
    "Never throw in DNS query path",
    "Never use sequential operations when parallel possible",
    "Never skip documentation updates",
    "Never hardcode values (use constants)"
  ],

  "completionCriteria": {
    "required": [
      "npm run build passes in affected module",
      "Tests added/updated in Test/",
      "cd Test && npm test passes",
      "Performance targets met (<5ms DB, <50ms upstream)",
      "Documentation updated (README, ARCHITECTURE, FEATURES)",
      "Backward compatible (no breaking changes)",
      "LAN-only deployment emphasized",
      "No 'any' types used",
      "Proper error handling (no throws in DNS path)"
    ]
  },

  "commands": {
    "serverBuild": "cd server && npm run build",
    "serverDev": "cd server && npm run dev",
    "serverStart": "cd server && npm start",
    "webDev": "cd Web && npm run dev",
    "webBuild": "cd Web && npm run build",
    "dhcpBuild": "cd DHCP && npm run build",
    "dhcpStart": "cd DHCP && npm start",
    "test": "cd Test && npm test",
    "testPerf": "cd Test && npm run test:perf"
  }
}
